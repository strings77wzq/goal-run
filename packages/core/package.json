{
  "name": "@strings77wzq/goalrun-core",
  "version": "0.1.0",
  "description": "Core schemas, types, and utilities for GoalRun",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
