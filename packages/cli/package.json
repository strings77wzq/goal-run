{
  "name": "@strings77wzq/goalrun",
  "version": "0.1.0",
  "description": "CLI for GoalRun - goal-driven agent skills for software engineering",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "goalrun": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@strings77wzq/goalrun-core": "workspace:*",
    "@strings77wzq/goalrun-harness": "workspace:*",
    "@strings77wzq/goalrun-reporter": "workspace:*",
    "@strings77wzq/goalrun-security": "workspace:*",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strings77wzq/goal-run.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "goalrun",
    "agent",
    "skills",
    "goal-driven",
    "verification",
    "harness",
    "cli",
    "software-engineering"
  ],
  "license": "MIT",
  "author": "strings77wzq"
}
