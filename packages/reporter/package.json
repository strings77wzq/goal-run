{
  "name": "goalrun-reporter",
  "version": "0.1.0-alpha.1",
  "description": "Text and JSON output formatting for GoalRun",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "goalrun-core": "workspace:*",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strings77wzq/goal-run.git",
    "directory": "packages/reporter"
  },
  "keywords": [
    "goalrun",
    "agent",
    "skills",
    "goal-driven",
    "verification",
    "harness",
    "cli",
    "software-engineering"
  ],
  "license": "MIT",
  "author": "strings77wzq"
}
