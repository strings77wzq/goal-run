{
  "name": "goalrun-harness",
  "version": "0.1.0-alpha.4",
  "description": "Validation harnesses for GoalRun skills, goals, policies, and selection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "goalrun-core": "workspace:*",
    "goalrun-security": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strings77wzq/goal-run.git",
    "directory": "packages/harness"
  },
  "keywords": [
    "goalrun",
    "agent",
    "skills",
    "goal-driven",
    "verification",
    "harness",
    "cli",
    "software-engineering"
  ],
  "license": "MIT",
  "author": "strings77wzq",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
